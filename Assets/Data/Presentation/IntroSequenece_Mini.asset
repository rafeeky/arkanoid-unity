    holdDurationMs: 1800
    eraseSpeedMs: 20
  - pageIndex: 2
    text: "\uC77C\uBD80 \uC54C\uBC14\uD2B8\uB85C\uC2A4\uB294 \uBA39\uC774\uB97C \uCC3E\uC544
