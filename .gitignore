# Unity generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Mm]emoryCaptures/
/[Rr]ecordings/
/[Uu]ser[Ss]ettings/

# Asset meta files — only ignore when corresponding asset is ignored
!/[Aa]ssets/**/*.meta

# JetBrains Rider plugin (auto-generated)
/[Aa]ssets/Plugins/Editor/JetBrains*

# IDE / editor caches
.vs/
.idea/
.gradle/

# Auto-generated VS / Rider solution and project files
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity-generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash reports
sysinfo.txt
crashlytics-build.properties

# Build artifacts
*.apk
*.aab
*.unitypackage
*.app

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Auto-generated Android streaming assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# OS noise
.DS_Store
Thumbs.db
